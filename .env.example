# Databases for migrations
DB_URL_DEV=postgresql+psycopg2://postgres:change_me@localhost:5432/smartenergy_dev
DB_URL_PROD=postgresql+psycopg2://postgres:change_me@localhost:5432/smartenergy_prod

# Backup settings (optional)
BACKUP_ROOT=./backups
BACKUP_RETENTION_DAYS=14
BACKUP_VERIFY=1
# Example: RCLONE_REMOTE=gdrive:smart-db-migrator
RCLONE_REMOTE=

# Minimal required vars for smart_common settings bootstrap
POSTGRES_PASSWORD=change_me
JWT_SECRET=change_me
FERNET_KEY=change_me
EMAIL_HOST=localhost
EMAIL_FROM=no-reply@smartenergy.local
